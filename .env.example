# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://identity_graph:change-me@localhost:5432/identity_graph
DATABASE_CONNECT_TIMEOUT_MS=5000
DATABASE_POOL_SIZE=10

# Auth
JWT_SECRET=

# Graph DB
NEO4J_ENABLED=false
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_ENCRYPTED=true
NEO4J_QUERY_TIMEOUT_MS=30000

# Active Directory / LDAP connector (disabled until a connector is explicitly enabled)
LDAP_URL=
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_TLS=true
LDAP_TLS_REJECT_UNAUTHORIZED=true
LDAP_CONNECT_TIMEOUT_MS=5000
LDAP_OPERATION_TIMEOUT_MS=15000
LDAP_PAGE_SIZE=500

# FreeIPA connector (disabled until a connector is explicitly enabled)
# FREEIPA_URL=ldaps://ipa.example.com
# FREEIPA_BASE_DN=dc=example,dc=com
# FREEIPA_BIND_DN=cn=directory manager
# FREEIPA_BIND_PASSWORD=
# FREEIPA_TLS=true
# FREEIPA_TLS_REJECT_UNAUTHORIZED=true
# FREEIPA_CONNECT_TIMEOUT_MS=5000
# FREEIPA_OPERATION_TIMEOUT_MS=15000
# FREEIPA_PAGE_SIZE=500

# Linux SSH connector (disabled until a connector is explicitly enabled)
# SSH_HOST=
# SSH_PORT=22
# SSH_USERNAME=
# SSH_PASSWORD=
# SSH_CONNECT_TIMEOUT_MS=10000
# SSH_COMMAND_TIMEOUT_MS=30000
# SSH_HOST_KEY_FINGERPRINT=
# SSH_STRICT_HOST_KEY_CHECKING=true

# Microsoft Entra ID connector (disabled until a connector is explicitly enabled)
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
# ENTRA_USE_DEVICE_CODE=false
# ENTRA_REDIRECT_URI=http://localhost:3000/auth/callback

# Import configuration (enterprise capacity)
# IMPORT_MAX_FILE_SIZE_MB=250
# IMPORT_MAX_FILES_PER_SESSION=50
# IMPORT_MAX_ROWS_PER_FILE=1000000
# IMPORT_MAX_ROWS_PER_SHEET=500000
# IMPORT_MAX_SHEETS_PER_WORKBOOK=100
# IMPORT_PREVIEW_ROWS=100
# IMPORT_PREVIEW_COLUMNS=100
# IMPORT_MAX_CELL_LENGTH=20000
# IMPORT_SESSION_TTL_MINUTES=240
# IMPORT_MAX_CONCURRENT_SESSIONS=10
# IMPORT_MAX_CONCURRENT_FILES=3
# IMPORT_CHUNK_SIZE_ROWS=5000
# IMPORT_UPLOAD_DIR=.imports-tmp
