{
  "name": "backend",
  "private": true,
  "version": "0.0.1",
  "description": "Identity Access Graph - Backend",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "test": "npm run test:unit && npm run test:integration && npm run test:graph-integration",
    "test:unit": "NODE_ENV=test tsx --test src/pipeline/__tests__/*.test.ts src/imports/__tests__/*.test.ts src/neo4j/__tests__/*.test.ts src/risk/__tests__/*.test.ts src/attack-path/__tests__/*.test.ts src/connectors/__tests__/*.test.ts src/identity/__tests__/*.test.ts src/notifications/__tests__/*.test.ts src/settings/__tests__/*.test.ts",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test:integration": "NODE_ENV=test tsx --test src/database/__tests__/*.integration.test.ts",
    "test:graph-integration": "NODE_ENV=test tsx --test src/graph/__tests__/*.integration.test.ts",
    "smoke:attack-path": "NODE_ENV=test tsx --test src/attack-path/__tests__/attack-path.runtime-smoke.test.ts",
    "migration:run": "node node_modules/typeorm/cli-ts-node-commonjs.js -d src/database/data-source.ts migration:run",
    "migration:revert": "node node_modules/typeorm/cli-ts-node-commonjs.js -d src/database/data-source.ts migration:revert"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@nestjs/common": "^10.4.1",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.1",
    "@nestjs/platform-express": "^10.4.1",
    "@nestjs/swagger": "^7.4.1",
    "@nestjs/typeorm": "^10.0.2",
    "@types/multer": "^2.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parse": "^6.1.0",
    "ldapts": "^7.4.0",
    "multer": "^2.2.0",
    "neo4j-driver": "^5.28.3",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ssh2": "^1.17.0",
    "typeorm": "^0.3.31",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.4.1",
    "@types/ssh2": "^1.15.5",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^5.5.4"
  }
}
